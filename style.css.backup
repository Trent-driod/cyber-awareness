* {
  box-sizing: border-box;
}

.page-overlay {
  pointer-events: none;
  position: fixed;
  inset: 0;
  background: radial-gradient(circle at 80% 20%, rgba(19,195,255,0.2), rgba(8,16,36,0.92));
  z-index: 9999;
  opacity: 0.8;
  transition: opacity 0.6s ease;
}

.header-animated {
  animation: glowPulse 2.1s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% { box-shadow: 0 0 20px rgba(19,195,255,0.3), 0 0 26px rgba(40,240,176,0.22); }
  50% { box-shadow: 0 0 30px rgba(19,195,255,0.8), 0 0 36px rgba(40,240,176,0.4); }
}

.page-overlay.hidden {
  opacity: 0;
  visibility: hidden;
}

.scroll-progress {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 4px;
  background: rgba(255, 255, 255, 0.06);
  z-index: 9998;
}

.scroll-bar {
  width: 0;
  height: 100%;
  background: linear-gradient(90deg, #13c3ff, #28f0b0);
  transition: width 0.15s ease;
}

.animate-item {
  opacity: 0;
  transform: translateY(22px);
  transition: opacity 0.75s ease, transform 0.75s ease;
}

.animate-item.in-view {
  opacity: 1;
  transform: translateY(0);
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: \"Segoe UI\", Tahoma, Geneva, Verdana, sans-serif;
  margin: 0;
  padding: 0;
  line-height: 1.6;
  background: #0b1120;
  color: #f5f9ff;
  opacity: 1;
  transition: opacity 0.45s ease;
}

body.fade-in {
  opacity: 1;
}

body.fade-out {
  opacity: 0;
}

.container {
  width: min(1100px, 95%);
  margin: 0 auto;
}

header {
  position: relative;
  background: linear-gradient(90deg, #0b1120 0%, #101a2f 40%, #0a122a 100%);
  color: #13c3ff;
  padding: 18px 0;
  border-bottom: 2px solid #13c3ff;
  box-shadow: 0 4px 14px rgba(0,0,0,0.45);
}

header::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -2px;
  width: 60%;
  height: 2px;
  transform: translateX(-50%);
  background: linear-gradient(90deg, rgba(19,195,255,.1), rgba(40,240,176,.7), rgba(19,195,255,.1));
}

a {
  color: #13c3ff;
}

a:hover {
  color: #9ef4ff;
}

.btn {
  background: #13c3ff;
  color: #0b1120;
  border: 1px solid #28f0b0;
}

.btn:hover,
.btn:focus {
  background: #28f0b0;
  color: #0b1120;
}

.header-inner {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
}

.brand-logo {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
  color: #13c3ff;
  font-weight: 900;
}

.brand-logo img {
  width: 70px;
  height: auto;
  object-fit: contain;
  border: 2px solid #28f0b0;
  border-radius: 0;
  background: transparent;
  box-shadow: 0 0 14px rgba(40, 240, 176, 0.45);
}

.brand-logo span {
  font-size: clamp(1.5rem, 3vw, 2.6rem);
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.6px;
}

header h1 {
  margin: 0;
  font-size: clamp(1.6rem, 3vw, 2.8rem);
  letter-spacing: 1px;
  text-shadow: 0 0 14px rgba(19, 195, 255, 0.55);
  display: flex;
  align-items: center;
  gap: 0.6rem;
}

.header-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2.1rem;
  height: 2.1rem;
  color: #0f0f0f;
  border-radius: 50%;
  background: linear-gradient(135deg, #13c3ff 0%, #28f0b0 100%);
  box-shadow: 0 0 18px rgba(19, 195, 255, 0.45), 0 0 0 2px rgba(40, 240, 176, 0.2);
}

 .header-icon {
  font-size: 1.2rem;
  width: 2.1rem;
  height: 2.1rem;
  line-height: 2.1rem;
  text-align: center;
}

.header-icon svg {
  width: 1.2rem;
  height: 1.2rem;
}

header p {
  margin: 6px 0 0;
  font-size: 0.95rem;
  color: #fff3b5;
}

nav ul {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  gap: 12px;
}

nav ul li a {
  color: #13c3ff;
  text-decoration: none;
  padding: 8px 12px;
  border-radius: 7px;
  border: 1px solid transparent;
  transition: all 0.2s ease;
}

nav ul li a:hover,
nav ul li a:focus {
  background: rgba(19, 195, 255, 0.22);
  color: #ffffff;
  border-color: #28f0b0;
}

.hero {
  background: linear-gradient(135deg, #081020 0%, #1b2b44 48%, #0a163a 100%);
  color: #ffffff;
  text-align: center;
  padding: 64px 16px;
}

.hero h2 {
  font-size: clamp(2rem, 5vw, 3.2rem);
  margin: 0 0 14px;
  color: #13c3ff;
  animation: pulseTitle 2.2s ease-in-out infinite;
}

.hero h2 span {
  display: inline-block;
  animation: slideHighlight 3.5s ease-in-out infinite;
}

@keyframes pulseTitle {
  0%, 100% { transform: translateY(0); opacity: 1; }
  50% { transform: translateY(-2px); opacity: .95; }
}

@keyframes slideHighlight {
  0%, 100% { transform: translateX(0); color: #13c3ff; }
  50% { transform: translateX(6px); color: #e0f6ff; }
}

.hero-image-wrap {
  margin: 18px auto 20px;
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  justify-content: center;
  align-items: flex-start;
}

.gallery-section {
  padding: 3rem 0;
}

.gallery-section h2 {
  color: #13c3ff;
  text-align: center;
  font-size: clamp(1.5rem, 3vw, 2.6rem);
  margin: 0 0 0.5rem;
}

.gallery-intro {
  text-align: center;
  color: #dfe6ff;
  font-size: 1rem;
  margin: 0 0 1.6rem;
  max-width: 780px;
  margin-inline: auto;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1rem;
  align-items: start;
}

.gallery-item {
  position: relative;
  background: linear-gradient(145deg, rgba(10,24,42,.75), rgba(6,14,26,.85));
  border: 1px solid rgba(40,240,176,0.3);
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 8px 20px rgba(0,0,0,0.35);
  transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  cursor: pointer;
}

.gallery-item:hover,
.gallery-item:focus-within {
  transform: translateY(-5px);
  box-shadow: 0 16px 28px rgba(0,0,0,0.45);
  border-color: rgba(40,240,176,0.7);
}

.gallery-item img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  display: block;
}

.gallery-caption {
  margin: 0;
  padding: 0.85rem 1rem;
  color: #f5f9ff;
  font-size: 0.95rem;
  line-height: 1.35;
  text-align: center;
}

.lightbox-overlay {
  --bg: rgba(0, 0, 0, .88);
  position: fixed;
  inset: 0;
  z-index: 100000;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: var(--bg);
  backdrop-filter: blur(2px);
  opacity: 1;
  transition: opacity 0.25s ease;
}

.lightbox-overlay.hidden {
  visibility: hidden;
  opacity: 0;
  pointer-events: none;
}

.lightbox-image {
  width: clamp(280px, 70vw, 860px);
  max-height: 80vh;
  object-fit: contain;
  border-radius: 8px;
  box-shadow: 0 14px 34px rgba(0, 0, 0, 0.6);
}

.lightbox-caption {
  margin-top: 0.8rem;
  color: #e5f2ff;
  font-size: 0.95rem;
  text-align: center;
  max-width: 760px;
}

.lightbox-close {
  position: absolute;
  top: 14px;
  right: 14px;
  width: 38px;
  height: 38px;
  border: none;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.48);
  color: #ffffff;
  font-size: 1.4rem;
  line-height: 34px;
  cursor: pointer;
  transition: background .2s ease;
}

.lightbox-close:hover,
.lightbox-close:focus {
  background: rgba(40, 240, 176, 0.8);
}

@media (max-width: 520px) {
  .gallery-item img {
    height: 180px;
  }

  .gallery-caption {
    font-size: 0.88rem;
    padding: 0.75rem 0.9rem;
  }
}


.gallery-section {
  padding: 3rem 0;
}

.gallery-section h2 {
  color: #13c3ff;
  text-align: center;
  font-size: clamp(1.5rem, 3vw, 2.6rem);
  margin: 0 0 0.5rem;
}

.gallery-intro {
  text-align: center;
  color: #dfe6ff;
  font-size: 1rem;
  margin: 0 0 1.6rem;
  max-width: 780px;
  margin-inline: auto;
}

.gallery-grid {
  display: grid;
